rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (admin/client)
    //
    // Collection: services
    // Fields:
    //   - name: string (required)
    //   - description: string
    //   - price: number (required)
    //   - duration: string
    //   - icon: string
    //
    // Collection: bookings
    // Fields:
    //   - customerName: string (required)
    //   - customerPhone: string (required)
    //   - address: string (required)
    //   - serviceId: string (required)
    //   - serviceName: string
    //   - date: string (required)
    //   - time: string (required)
    //   - status: string (pending/confirmed/completed/cancelled)
    //   - paymentMethod: string (online/local)
    //   - totalPrice: number
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "phelippes593@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isBookingOwner(data) {
      return isAuthenticated() && data.userId == request.auth.uid;
    }

    function isValidBooking(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.customerPhone is string && data.customerPhone.size() >= 8 && data.customerPhone.size() < 30 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.serviceId is string && data.serviceId.size() < 100 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.time is string && data.time.matches("^\\d{2}:\\d{2}$") &&
             (!('services' in data) || data.services is list) &&
             (!('serviceName' in data) || (data.serviceName is string && data.serviceName.size() < 500)) &&
             (!('totalPrice' in data) || data.totalPrice is number) &&
             (!('status' in data) || data.status in ['pending', 'confirmed', 'completed', 'cancelled']) &&
             (!('paymentMethod' in data) || data.paymentMethod in ['online', 'local']) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() < 100));
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isValidBooking(request.resource.data) && 
                    (!('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() && isValidBooking(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
